{
  "name": "sidsru.github.io",
  "version": "1.0.0",
  "description": "Personal blog built with Jekyll and Chirpy.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidsru/sidsru.github.io.git"
  },
